<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.rasel.pdfviewer">

    <!-- Storage permissions for reading PDF files -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.PdfViewer">

        <!-- ✅ PDF Viewer Activity — default system PDF viewer -->
        <activity
            android:name=".PdfViewerActivity"
            android:label="@string/app_name"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:hardwareAccelerated="true"
            android:theme="@style/Theme.PdfViewer"
            android:configChanges="orientation|screenSize|keyboardHidden">

            <!-- Launcher icon -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- content:// URI — MediaStore, Drive, Downloads -->
            <intent-filter android:priority="100">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" android:mimeType="application/pdf" />
            </intent-filter>

            <!-- file:// URI — older file managers -->
            <intent-filter android:priority="100">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="application/pdf" />
            </intent-filter>

            <!-- .pdf extension fallback (content:// with pathPattern) -->
            <intent-filter android:priority="90">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:pathPattern=".*\.pdf" />
            </intent-filter>

        </activity>

        <!-- FIX: com.artifex.mupdf:viewer's own AAR declares DocumentActivity
             with an intent-filter but no explicit android:exported — required
             by Android 12+ for any component with an intent-filter, and the
             library's manifest predates that requirement. Overriding here via
             manifest merge. Our own .PdfViewerActivity above already serves
             as the app's externally-launchable PDF viewer (exported=true with
             full intent-filters), so this one only needs to be reachable from
             inside this app — exported=false. -->
        <activity
            android:name="com.artifex.mupdf.viewer.DocumentActivity"
            android:exported="false"
            tools:node="merge" />

        <!-- FileProvider for sharing internal cache files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
