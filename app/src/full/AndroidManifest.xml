<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>
        <!-- FIX: Android 12+ requires android:exported for activities with intent-filter.
             MuPDF's DocumentActivity has intent-filter but no exported flag.
             tools:node="merge" forces our exported=true into the merged manifest. -->
        <activity
            android:name="com.artifex.mupdf.viewer.DocumentActivity"
            android:exported="true"
            tools:node="merge" />
    </application>

</manifest>
